<ConceptIndexPage @concept={{@model.mainConcept}}
                  @relatedSigns={{@model.relatedSigns}}
                  @relatedMarkings={{@model.relatedMarkings}}
                  @relatedLights={{@model.relatedLights}}
>
  <:belowInstructions>
    {{#if this.isSubSign}}
      <SearchTables::RoadSign @content={{sort-by-road-sign-code (await @model.mainConcept.mainSigns)}}>
        <:menu>
          <AuToolbar class="au-o-box" as |Group|>
            <Group>
              <AuHeading @level="2" @skin="3">
                {{t "road-sign-concept.attr.main-sign"}}
              </AuHeading>
            </Group>
            <Group>
              <AuLink @skin="button" @route="road-sign-concepts.road-sign-concept.subsigns">
                {{t "main-sign.crud.add"}}
              </AuLink>
            </Group>
          </AuToolbar>
        </:menu>
      </SearchTables::RoadSign>
    {{else}}
      <SearchTables::RoadSign @content={{sort-by-road-sign-code (await @model.mainConcept.subSigns)}}>
        <:menu>
          <AuToolbar class="au-o-box" as |Group|>
            <Group>
              <AuHeading @level="2" @skin="3">
                {{t "road-sign-concept.attr.sub-sign"}}
              </AuHeading>
            </Group>
            <Group>
              <AuLink @skin="button" @route="road-sign-concepts.road-sign-concept.subsigns">
                {{t "sub-sign.crud.add"}}
              </AuLink>
            </Group>
          </AuToolbar>
        </:menu>
      </SearchTables::RoadSign>
    {{/if}}
  </:belowInstructions>
</ConceptIndexPage>