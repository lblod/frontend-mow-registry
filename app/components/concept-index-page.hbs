<div
  class="au-c-body-container au-c-body-container--scroll au-c-body-container--tables"
>
  <InstructionsTable
    @templates={{this.concept.templates}}
    @removeTemplate={{perform this.removeTemplate}}
  >
    <:menu>
      <AuToolbar class="au-o-box" as |Group|>
        <Group>
          <AuHeading @level="2" @skin="3">
            {{t "utility.instructions"}}
          </AuHeading>
        </Group>
        <Group>
          <AuLink
            @route={{relative-route "instruction"}}
            @model="new"
            @skin="button"
          >
            {{t "utility.add-instruction"}}
          </AuLink>
        </Group>
      </AuToolbar>
    </:menu>
    <:edit as |template|>
      <AuLink
        @icon="pencil"
        @skin="button-secondary"
        @hideText={{true}}
        @route={{relative-route "instruction"}}
        @model={{template.id}}
      >
        {{t "utility.edit"}}
      </AuLink>
    </:edit>
    <:delete as |template|>
      {{#let (get this.show (unique-id)) as |show|}}
        <AuButton
          @icon="bin"
          @alert={{true}}
          @skin="button-secondary"
          @hideText={{true}}
          {{on "click" (fn (mut show) true)}}
        >
          {{t "utility.delete"}}
        </AuButton>
        <AreYouSureModal 
          @onConfirm={{perform this.removeTemplate template}} 
          @modalOpen={{show}} 
        />
      {{/let}}
    </:delete>
  </InstructionsTable>
  {{#if (has-block 'belowInstructions')}}    
    {{yield to='belowInstructions'}}
  {{/if}}
  <SearchTables::RoadSign
    @content={{sort-by-road-sign-code @relatedSigns}}
  >
    <:menu>
      <AuToolbar class="au-o-box" as |Group|>
        <Group>
          <AuHeading @level="2" @skin="3">
            {{t "road-sign-concept.attr.related-sign"}}
          </AuHeading>
        </Group>
        <Group>
          <AuLink @skin="button" @route={{relative-route "related-signs"}}>
            {{t "related-road-sign.crud.add"}}
          </AuLink>
        </Group>
      </AuToolbar>
    </:menu>

  </SearchTables::RoadSign>
  <SearchTables::RoadMarking
    @content={{sort-by-road-marking-code @relatedMarkings}}
  >
    <:menu>
      <AuToolbar class="au-o-box" as |Group|>
        <Group>
          <AuHeading @level="2" @skin="3">
            {{t "road-sign-concept.attr.related-marking"}}
          </AuHeading>
        </Group>
        <Group>
          <AuLink @skin="button" @route={{relative-route "related-markings"}}>
            {{t "related-road-marking.crud.add"}}
          </AuLink>
        </Group>
      </AuToolbar>
    </:menu>
  </SearchTables::RoadMarking>
  <SearchTables::TrafficLight
    @content={{sort-by-traffic-light-code @relatedLights}}
  >
    <:menu>
      <AuToolbar class="au-o-box" as |Group|>
        <Group>
          <AuHeading @level="2" @skin="3">
            {{t "road-sign-concept.attr.related-traffic-light"}}
          </AuHeading>
        </Group>
        <Group>
          <AuLink @skin="button" @route={{relative-route "related-lights"}}>
            {{t "related-traffic-light.crud.add"}}
          </AuLink>
        </Group>
      </AuToolbar>
    </:menu>
  </SearchTables::TrafficLight>
</div>